          },
          "intermediate_data": {
            "tool_uses": [
              { "name": "search_github_code", "args": { "query": "\"/api/users\" repo:google/adk" } }
            ]
          }
        }
      ],
      "session_input": {
        "app_name": "app",
        "user_id": "eval_user",
        "state": {}
      }
    },
    {
      "eval_id": "commit_analysis",
      "conversation": [
        {
          "user_content": {
            "parts": [{"text": "Can you check the recent commits for 'google/adk' in 'src/auth'?"}]
          },
          "intermediate_data": {
            "tool_uses": [
              { "name": "get_recent_commits", "args": { "repo": "google/adk", "path": "src/auth" } }
